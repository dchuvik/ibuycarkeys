---
import Layout from "~/layouts/Layout.astro";
import Section from "~/components/Section.astro";
import Container from "~/components/Container.astro";
import Heading from "~/components/Heading.astro";
import KeyQuoteBuilder from "~/components/forms/KeyQuoteBuilder.astro";
import { getPriceCatalog, getPriceCatalogMakes } from "~/data/priceCatalog";

const priceCatalog = await getPriceCatalog();
const priceCatalogMakes = await getPriceCatalogMakes();
---

<Layout
	pageTitle="Sell Your Car Keys"
	title="Sell Your Car Keys"
	description="Search your car key, get an instant payout estimate, and keep track of every key in one quote cart."
>
	<Section class:list={"bg-gradient-to-br from-slate-100 via-white to-sky-50"}>
		<Container>
			<div class="grid grid-cols-1 gap-10 lg:grid-cols-[minmax(0,1.05fr)_minmax(0,0.95fr)] lg:items-center">
				<div class="prose max-w-3xl">
					<p class="mb-3 text-sm font-semibold uppercase tracking-[0.2em] text-sky-700">
						Instant car key quotes
					</p>
					<h1 class="mb-4 text-balance">Turn loose car keys into a fast payout quote</h1>
					<p>
						Choose your vehicle make, find the key that matches what you have, and see your payout update as
						you add keys to your quote.
					</p>
				</div>

				<div class="grid grid-cols-1 gap-4 rounded-3xl bg-gray-900 p-6 text-white shadow-xl sm:grid-cols-3">
					<div>
						<p class="text-sm text-gray-300">Supported makes</p>
						<p class="mt-2 text-4xl font-bold text-sky-300">{priceCatalogMakes.length}</p>
					</div>
					<div>
						<p class="text-sm text-gray-300">SKU items</p>
						<p class="mt-2 text-4xl font-bold text-sky-300">{priceCatalog.length}</p>
					</div>
					<div>
						<p class="text-sm text-gray-300">Highest payout</p>
						<p class="mt-2 text-4xl font-bold text-sky-300">$60</p>
					</div>
				</div>
			</div>
		</Container>
	</Section>

	<Section>
		<Container>
			<KeyQuoteBuilder />
		</Container>
	</Section>

	<Section id="how-it-works" class:list={"bg-gray-50"}>
		<Container>
			<Heading class:list={"max-w-3xl"}>
				<h2 slot="heading-title">How it works</h2>
				<p slot="heading-content">
					Getting a quote is simple. Search for your key, review the payout, and keep adding keys until your
					quote is complete.
				</p>
			</Heading>

			<div class="grid grid-cols-1 gap-6 lg:grid-cols-3">
				<div class="rounded-3xl bg-white p-6 shadow-sm ring-1 ring-gray-100">
					<p class="text-sm font-semibold uppercase tracking-[0.15em] text-sky-700">1. Select</p>
					<h3 class="mt-3 text-2xl font-bold">Find your key</h3>
					<p class="mt-3 text-gray-600">
						Choose your make, search by SKU, FCC ID, or description, and select the key that matches what you
						have.
					</p>
				</div>

				<div class="rounded-3xl bg-white p-6 shadow-sm ring-1 ring-gray-100">
					<p class="text-sm font-semibold uppercase tracking-[0.15em] text-sky-700">2. Price</p>
					<h3 class="mt-3 text-2xl font-bold">Review your payout</h3>
					<p class="mt-3 text-gray-600">
						Check the estimated payout, choose the condition if it applies, and set the quantity before adding
						it to your quote.
					</p>
				</div>

				<div class="rounded-3xl bg-white p-6 shadow-sm ring-1 ring-gray-100">
					<p class="text-sm font-semibold uppercase tracking-[0.15em] text-sky-700">3. Track</p>
					<h3 class="mt-3 text-2xl font-bold">Build your full quote</h3>
					<p class="mt-3 text-gray-600">
						Keep adding keys to your quote cart and see the running total update as you go.
					</p>
				</div>
			</div>
		</Container>
	</Section>
</Layout>

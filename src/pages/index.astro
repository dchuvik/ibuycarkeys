---
import Layout from "~/layouts/Layout.astro";
import Section from "~/components/Section.astro";
import Container from "~/components/Container.astro";
import Heading from "~/components/Heading.astro";
import KeyQuoteBuilder from "~/components/forms/KeyQuoteBuilder.astro";
import PriceCatalog from "~/components/PriceCatalog.astro";
import { priceCatalog, priceCatalogMakes } from "~/data/priceCatalog";
---

<Layout
	pageTitle="Sell Your Car Keys"
	title="Sell Your Car Keys"
	description="Get an instant payout quote for used car keys, build a quote cart, and keep track of every key entered."
>
	<Section class:list={"bg-gradient-to-br from-amber-100 via-white to-yellow-50"}>
		<Container>
			<div class="grid grid-cols-1 gap-10 lg:grid-cols-[minmax(0,1.05fr)_minmax(0,0.95fr)] lg:items-center">
				<div class="prose max-w-3xl">
					<p class="mb-3 text-sm font-semibold uppercase tracking-[0.2em] text-amber-700">
						Car key buying quotes
					</p>
					<h1 class="mb-4 text-balance">Turn loose car keys into a fast payout quote</h1>
					<p>
						This version of the template is now set up for buying car keys. Customers can search the real SKU
						price list, choose the exact item, set quantity, and build a running quote cart that totals the
						payout instantly.
					</p>
				</div>

				<div class="grid grid-cols-1 gap-4 rounded-3xl bg-gray-900 p-6 text-white shadow-xl sm:grid-cols-3">
					<div>
						<p class="text-sm text-gray-300">Supported makes</p>
						<p class="mt-2 text-4xl font-bold text-amber-300">{priceCatalogMakes.length}</p>
					</div>
					<div>
						<p class="text-sm text-gray-300">SKU items</p>
						<p class="mt-2 text-4xl font-bold text-amber-300">{priceCatalog.length}</p>
					</div>
					<div>
						<p class="text-sm text-gray-300">Highest payout</p>
						<p class="mt-2 text-4xl font-bold text-amber-300">$60</p>
					</div>
				</div>
			</div>
		</Container>
	</Section>

	<Section>
		<Container>
			<KeyQuoteBuilder />
		</Container>
	</Section>

	<Section class:list={"bg-gray-50"}>
		<Container>
			<PriceCatalog />
		</Container>
	</Section>

	<Section id="how-it-works" class:list={"bg-gray-50"}>
		<Container>
			<Heading class:list={"max-w-3xl"}>
				<h2 slot="heading-title">How the quote workflow works</h2>
				<p slot="heading-content">
					The site now behaves like a lightweight buying cart. Each key entry stays in the browser until the
					customer removes it or clears the cart, so they can build up a full quote across multiple vehicles.
				</p>
			</Heading>

			<div class="grid grid-cols-1 gap-6 lg:grid-cols-3">
				<div class="rounded-3xl bg-white p-6 shadow-sm ring-1 ring-gray-100">
					<p class="text-sm font-semibold uppercase tracking-[0.15em] text-amber-700">1. Select</p>
					<h3 class="mt-3 text-2xl font-bold">Search the actual SKU catalog</h3>
					<p class="mt-3 text-gray-600">
						Users can search by SKU, FCC ID, or description and then narrow the list by make before choosing
						the exact key they want to quote.
					</p>
				</div>

				<div class="rounded-3xl bg-white p-6 shadow-sm ring-1 ring-gray-100">
					<p class="text-sm font-semibold uppercase tracking-[0.15em] text-amber-700">2. Price</p>
					<h3 class="mt-3 text-2xl font-bold">Use standard or worn pricing</h3>
					<p class="mt-3 text-gray-600">
						The form can apply either the standard payout or the worn payout when that lower condition price
						exists in your list.
					</p>
				</div>

				<div class="rounded-3xl bg-white p-6 shadow-sm ring-1 ring-gray-100">
					<p class="text-sm font-semibold uppercase tracking-[0.15em] text-amber-700">3. Track</p>
					<h3 class="mt-3 text-2xl font-bold">Keep every key in the quote cart</h3>
					<p class="mt-3 text-gray-600">
						The cart stores each entry locally in the browser and keeps a running total payout for the full
						batch of keys.
					</p>
				</div>
			</div>
		</Container>
	</Section>
</Layout>

---
import Container from "~/components/Container.astro";
import Section from "~/components/Section.astro";
import Layout from "~/layouts/Layout.astro";

export const prerender = false;

const supabaseUrl = process.env.SUPABASE_URL ?? "";
const supabaseAnonKey = process.env.SUPABASE_ANON_KEY ?? "";
---

<Layout
	pageTitle="Account"
	title="Account"
	description="Create an account, sign in, and review your quote history."
	noindex={true}
>
	<Section class:list={"bg-gradient-to-br from-stone-100 via-white to-amber-50"}>
		<Container>
			<div
				id="account-app"
				data-supabase-url={supabaseUrl}
				data-supabase-anon-key={supabaseAnonKey}
				class="mx-auto max-w-6xl space-y-8"
			>
				<div class="flex flex-col gap-4 rounded-[2rem] bg-gray-950 px-6 py-8 text-white shadow-2xl sm:px-8">
					<p class="text-sm font-semibold uppercase tracking-[0.22em] text-amber-300">Repeat seller access</p>
					<h1 class="text-4xl font-bold tracking-[-0.03em]">Account</h1>
					<p class="max-w-3xl text-sm leading-6 text-gray-300">
						Create an account to save your profile details and review your previous quote orders any time.
					</p>
				</div>

				<p id="account-status" class="rounded-2xl bg-white px-5 py-4 text-sm text-gray-600 shadow-sm ring-1 ring-gray-200">
					Checking your account session...
				</p>

				<div id="auth-panel" class="grid grid-cols-1 gap-6 lg:grid-cols-2">
					<div class="rounded-[2rem] bg-white p-6 shadow-xl ring-1 ring-gray-200">
						<p class="text-sm font-semibold uppercase tracking-[0.16em] text-amber-700">Sign in</p>
						<h2 class="mt-2 text-3xl font-bold text-gray-950">Welcome back</h2>
						<form id="sign-in-form" class="mt-6 space-y-4">
							<div>
								<label for="sign-in-email">Email</label>
								<input id="sign-in-email" name="email" type="email" autocomplete="email" required />
							</div>
							<div>
								<label for="sign-in-password">Password</label>
								<input
									id="sign-in-password"
									name="password"
									type="password"
									autocomplete="current-password"
									required
								/>
							</div>
							<button type="submit" class="button button-black min-h-12 rounded-full px-6">Sign in</button>
						</form>
					</div>

					<div class="rounded-[2rem] bg-white p-6 shadow-xl ring-1 ring-gray-200">
						<p class="text-sm font-semibold uppercase tracking-[0.16em] text-amber-700">Create account</p>
						<h2 class="mt-2 text-3xl font-bold text-gray-950">Save your repeat seller profile</h2>
						<form id="sign-up-form" class="mt-6 space-y-4">
							<div>
								<label for="sign-up-name">Full name</label>
								<input id="sign-up-name" name="full_name" type="text" autocomplete="name" required />
							</div>
							<div>
								<label for="sign-up-email">Email</label>
								<input id="sign-up-email" name="email" type="email" autocomplete="email" required />
							</div>
							<div>
								<label for="sign-up-phone">Phone</label>
								<input id="sign-up-phone" name="phone" type="tel" autocomplete="tel" />
							</div>
							<div>
								<label for="sign-up-password">Password</label>
								<input
									id="sign-up-password"
									name="password"
									type="password"
									autocomplete="new-password"
									minlength="8"
									required
								/>
							</div>
							<button type="submit" class="button button-yellow min-h-12 rounded-full px-6">Create account</button>
						</form>
					</div>
				</div>

				<div id="account-dashboard" class="hidden space-y-8">
					<div class="flex flex-col gap-4 rounded-3xl bg-white px-6 py-5 shadow-sm ring-1 ring-gray-200 sm:flex-row sm:items-center sm:justify-between">
						<div>
							<p class="text-sm font-semibold uppercase tracking-[0.16em] text-amber-700">Signed in</p>
							<p id="account-email" class="mt-2 text-lg font-bold text-gray-950"></p>
						</div>
						<button id="sign-out-button" type="button" class="button button-white min-h-11 rounded-full border border-gray-200 px-5">
							Sign out
						</button>
					</div>

					<div class="grid grid-cols-1 gap-6 lg:grid-cols-[minmax(0,0.9fr)_minmax(0,1.1fr)]">
						<div class="rounded-[2rem] bg-white p-6 shadow-xl ring-1 ring-gray-200">
							<p class="text-sm font-semibold uppercase tracking-[0.16em] text-amber-700">Profile</p>
							<h2 class="mt-2 text-3xl font-bold text-gray-950">Saved seller details</h2>
							<form id="profile-form" class="mt-6 grid grid-cols-1 gap-4 sm:grid-cols-2">
								<div class="sm:col-span-2">
									<label for="profile-name">Full name</label>
									<input id="profile-name" name="full_name" type="text" autocomplete="name" />
								</div>
								<div class="sm:col-span-2">
									<label for="profile-phone">Phone</label>
									<input id="profile-phone" name="phone" type="tel" autocomplete="tel" />
								</div>
								<div class="sm:col-span-2">
									<label for="profile-address">Address</label>
									<input id="profile-address" name="address" type="text" autocomplete="street-address" />
								</div>
								<div>
									<label for="profile-city">City</label>
									<input id="profile-city" name="city" type="text" autocomplete="address-level2" />
								</div>
								<div>
									<label for="profile-state">State</label>
									<input id="profile-state" name="state" type="text" autocomplete="address-level1" maxlength="2" />
								</div>
								<div>
									<label for="profile-zip">ZIP</label>
									<input id="profile-zip" name="zip" type="text" autocomplete="postal-code" />
								</div>
								<div class="sm:col-span-2">
									<button type="submit" class="button button-black min-h-12 rounded-full px-6">Save profile</button>
								</div>
							</form>
						</div>

						<div class="rounded-[2rem] bg-white p-6 shadow-xl ring-1 ring-gray-200">
							<div class="flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
								<div>
									<p class="text-sm font-semibold uppercase tracking-[0.16em] text-amber-700">Quote history</p>
									<h2 class="mt-2 text-3xl font-bold text-gray-950">Your quote orders</h2>
								</div>
								<p class="text-sm font-medium text-gray-500">
									Visible orders: <span id="account-orders-count" class="font-bold text-gray-950">0</span>
								</p>
							</div>

							<div class="mt-6">
								<label for="account-order-search">Search your orders</label>
								<input
									id="account-order-search"
									type="search"
									placeholder="Search by payout, address, key details, or date"
								/>
							</div>

							<div class="mt-6 overflow-hidden rounded-[1.5rem] border border-gray-200">
								<div class="overflow-x-auto">
									<table class="min-w-full border-collapse text-left">
										<thead class="bg-stone-100">
											<tr class="text-sm uppercase tracking-[0.12em] text-gray-500">
												<th class="px-4 py-4 font-semibold">Submitted</th>
												<th class="px-4 py-4 font-semibold">Keys</th>
												<th class="px-4 py-4 font-semibold">Payout</th>
												<th class="px-4 py-4 font-semibold">Delivery</th>
												<th class="px-4 py-4 font-semibold">Details</th>
											</tr>
										</thead>
										<tbody id="account-orders-body" class="divide-y divide-gray-200 bg-white"></tbody>
									</table>
								</div>
								<p id="account-orders-empty" class="px-5 py-10 text-center text-sm text-gray-500">
									You do not have any saved quote orders yet.
								</p>
							</div>
						</div>
					</div>
				</div>
			</div>
		</Container>
	</Section>
</Layout>

<script>
	document.addEventListener("astro:page-load", async () => {
		const root = document.getElementById("account-app");
		const status = document.getElementById("account-status");
		const authPanel = document.getElementById("auth-panel");
		const dashboard = document.getElementById("account-dashboard");
		const emailLabel = document.getElementById("account-email");
		const signInForm = document.getElementById("sign-in-form");
		const signUpForm = document.getElementById("sign-up-form");
		const profileForm = document.getElementById("profile-form");
		const signOutButton = document.getElementById("sign-out-button");
		const ordersSearch = document.getElementById("account-order-search");
		const ordersCount = document.getElementById("account-orders-count");
		const ordersBody = document.getElementById("account-orders-body");
		const ordersEmpty = document.getElementById("account-orders-empty");

		if (
			!(
				root instanceof HTMLElement &&
				status instanceof HTMLElement &&
				authPanel instanceof HTMLElement &&
				dashboard instanceof HTMLElement &&
				emailLabel instanceof HTMLElement &&
				signInForm instanceof HTMLFormElement &&
				signUpForm instanceof HTMLFormElement &&
				profileForm instanceof HTMLFormElement &&
				signOutButton instanceof HTMLButtonElement &&
				ordersSearch instanceof HTMLInputElement &&
				ordersCount instanceof HTMLElement &&
				ordersBody instanceof HTMLElement &&
				ordersEmpty instanceof HTMLElement
			)
		) {
			return;
		}

		const supabaseUrl = root.dataset.supabaseUrl ?? "";
		const supabaseAnonKey = root.dataset.supabaseAnonKey ?? "";

		if (!supabaseUrl || !supabaseAnonKey) {
			status.textContent = "Account auth is not configured yet.";
			return;
		}

		const { createClient } = await import("@supabase/supabase-js");
		const supabase = createClient(supabaseUrl, supabaseAnonKey);
		let currentSession = null;
		let orderRows = [];

		const setStatus = (message, tone = "neutral") => {
			status.textContent = message;
			status.className =
				tone === "error"
					? "rounded-2xl border border-red-200 bg-red-50 px-5 py-4 text-sm text-red-700 shadow-sm"
					: tone === "success"
						? "rounded-2xl border border-emerald-200 bg-emerald-50 px-5 py-4 text-sm text-emerald-700 shadow-sm"
						: "rounded-2xl bg-white px-5 py-4 text-sm text-gray-600 shadow-sm ring-1 ring-gray-200";
		};

		const formatDateTime = (value) =>
			new Intl.DateTimeFormat("en-US", {
				dateStyle: "medium",
				timeStyle: "short",
			}).format(new Date(value));

		const renderOrderFilters = () => {
			const query = ordersSearch.value.trim().toLowerCase();
			let visibleCount = 0;

			for (const row of orderRows) {
				const matches = !query || (row.dataset.search ?? "").includes(query);
				row.style.display = matches ? "" : "none";
				if (matches) {
					visibleCount += 1;
				}
			}

			ordersCount.textContent = String(visibleCount);
			ordersEmpty.classList.toggle("hidden", visibleCount > 0);
			ordersBody.parentElement?.parentElement?.classList.toggle("hidden", orderRows.length === 0);
		};

		const renderOrders = (orders) => {
			ordersBody.innerHTML = "";
			orderRows = [];

			if (!orders.length) {
				ordersCount.textContent = "0";
				ordersEmpty.textContent = "You do not have any saved quote orders yet.";
				ordersEmpty.classList.remove("hidden");
				return;
			}

			for (const order of orders) {
				const row = document.createElement("tr");
				row.dataset.search = `${order.submitted_at ?? ""} ${order.quote_summary ?? ""} ${order.estimated_payout ?? ""} ${order.customer_address ?? ""} ${order.customer_city ?? ""} ${order.customer_state ?? ""} ${order.customer_zip ?? ""}`.toLowerCase();
				row.className = "align-top";
				row.innerHTML = `
					<td class="px-4 py-4 text-sm text-gray-700">${formatDateTime(order.created_at)}</td>
					<td class="px-4 py-4 text-sm text-gray-700">${order.total_keys ?? "-"}</td>
					<td class="px-4 py-4 text-sm font-bold ${order.estimated_payout ? "text-emerald-700" : "text-gray-400"}">${order.estimated_payout ?? "Pending"}</td>
					<td class="px-4 py-4 text-sm text-gray-700">${order.customer_city}, ${order.customer_state} ${order.customer_zip}</td>
					<td class="px-4 py-4">
						<details class="rounded-2xl bg-stone-50 p-3 ring-1 ring-gray-200">
							<summary class="cursor-pointer list-none text-sm font-semibold text-gray-900">View quote</summary>
							<pre class="mt-3 overflow-x-auto whitespace-pre-wrap rounded-2xl bg-white px-3 py-3 text-sm leading-6 text-gray-700 ring-1 ring-gray-200">${order.quote_summary}</pre>
						</details>
					</td>
				`;
				orderRows.push(row);
				ordersBody.appendChild(row);
			}

			renderOrderFilters();
		};

		const loadAccountData = async (session) => {
			const user = session.user;
			emailLabel.textContent = user.email ?? "Signed in";

			const [{ data: profile }, { data: orders, error: ordersError }] = await Promise.all([
				supabase.from("profiles").select("*").eq("id", user.id).maybeSingle(),
				supabase.from("quote_requests").select("*").order("created_at", { ascending: false }),
			]);

			if (ordersError) {
				throw ordersError;
			}

			const nameField = document.getElementById("profile-name");
			const phoneField = document.getElementById("profile-phone");
			const addressField = document.getElementById("profile-address");
			const cityField = document.getElementById("profile-city");
			const stateField = document.getElementById("profile-state");
			const zipField = document.getElementById("profile-zip");

			if (
				nameField instanceof HTMLInputElement &&
				phoneField instanceof HTMLInputElement &&
				addressField instanceof HTMLInputElement &&
				cityField instanceof HTMLInputElement &&
				stateField instanceof HTMLInputElement &&
				zipField instanceof HTMLInputElement
			) {
				nameField.value = profile?.full_name ?? user.user_metadata?.full_name ?? "";
				phoneField.value = profile?.phone ?? user.user_metadata?.phone ?? "";
				addressField.value = profile?.address ?? "";
				cityField.value = profile?.city ?? "";
				stateField.value = profile?.state ?? "";
				zipField.value = profile?.zip ?? "";
			}

			renderOrders(orders ?? []);
		};

		const refreshSession = async () => {
			const {
				data: { session },
			} = await supabase.auth.getSession();
			currentSession = session;

			if (!session) {
				authPanel.classList.remove("hidden");
				dashboard.classList.add("hidden");
				setStatus("Sign in or create an account to save your seller profile and review your quote history.");
				return;
			}

			authPanel.classList.add("hidden");
			dashboard.classList.remove("hidden");
			await loadAccountData(session);
			setStatus("Your account is ready.", "success");
		};

		signInForm.addEventListener("submit", async (event) => {
			event.preventDefault();
			const formData = new FormData(signInForm);
			setStatus("Signing you in...");

			const { error } = await supabase.auth.signInWithPassword({
				email: String(formData.get("email") ?? ""),
				password: String(formData.get("password") ?? ""),
			});

			if (error) {
				setStatus(error.message, "error");
				return;
			}

			signInForm.reset();
			await refreshSession();
		});

		signUpForm.addEventListener("submit", async (event) => {
			event.preventDefault();
			const formData = new FormData(signUpForm);
			setStatus("Creating your account...");

			const { data, error } = await supabase.auth.signUp({
				email: String(formData.get("email") ?? ""),
				password: String(formData.get("password") ?? ""),
				options: {
					emailRedirectTo: `${window.location.origin}/account`,
					data: {
						full_name: String(formData.get("full_name") ?? ""),
						phone: String(formData.get("phone") ?? ""),
					},
				},
			});

			if (error) {
				setStatus(error.message, "error");
				return;
			}

			signUpForm.reset();

			if (!data.session) {
				setStatus("Your account was created. Check your email to confirm your account, then sign in.", "success");
				return;
			}

			await refreshSession();
		});

		profileForm.addEventListener("submit", async (event) => {
			event.preventDefault();

			if (!currentSession) {
				setStatus("Sign in before saving your profile.", "error");
				return;
			}

			const formData = new FormData(profileForm);
			setStatus("Saving your profile...");

			const { error } = await supabase.from("profiles").upsert({
				id: currentSession.user.id,
				email: currentSession.user.email,
				full_name: String(formData.get("full_name") ?? ""),
				phone: String(formData.get("phone") ?? ""),
				address: String(formData.get("address") ?? ""),
				city: String(formData.get("city") ?? ""),
				state: String(formData.get("state") ?? "").toUpperCase(),
				zip: String(formData.get("zip") ?? ""),
			});

			if (error) {
				setStatus(error.message, "error");
				return;
			}

			setStatus("Profile saved successfully.", "success");
		});

		signOutButton.addEventListener("click", async () => {
			await supabase.auth.signOut();
			await refreshSession();
		});

		ordersSearch.addEventListener("input", renderOrderFilters);
		supabase.auth.onAuthStateChange(async () => {
			await refreshSession();
		});

		await refreshSession();
	});
</script>

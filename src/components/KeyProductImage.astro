---
import LogoImage from "~/assets/images/icons/logo.svg";

const { imageUrl, alt = "Car key product", label = "Key" } = Astro.props;
const src = typeof imageUrl === "string" && imageUrl.trim().length ? imageUrl.trim() : LogoImage.src;
const badgeLabel = typeof label === "string" && label.trim().length ? label.trim() : "Key";
---

<div class="relative overflow-hidden rounded-xl bg-gradient-to-br from-slate-100 via-sky-50 to-white p-2">
	<div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,_rgba(14,165,233,0.18),_transparent_40%)]"></div>
	<img src={src} alt={alt} class="relative mx-auto aspect-[4/3] w-full rounded-lg object-contain" loading="lazy" />
	<div class="absolute bottom-2 right-2 rounded-full bg-white/85 px-2 py-0.5 text-[10px] font-semibold uppercase tracking-[0.12em] text-sky-700">
		{badgeLabel}
	</div>
</div>

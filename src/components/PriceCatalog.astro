---
import { priceCatalog, priceCatalogMakes } from "~/data/priceCatalog";
---

<section class="rounded-3xl bg-white p-6 shadow-sm ring-1 ring-gray-100 lg:p-8">
	<div class="flex flex-col gap-6 lg:flex-row lg:items-end lg:justify-between">
		<div class="max-w-3xl">
			<p class="text-sm font-semibold uppercase tracking-[0.2em] text-amber-700">Price list</p>
			<h2 class="mt-2 text-3xl font-bold">Searchable and filterable SKU catalog</h2>
			<p class="mt-3 text-gray-600">
				Search by SKU, FCC ID, vehicle name, or any keyword. Filter by make or by whether a worn-price value is
				available.
			</p>
		</div>
		<p id="catalog-results-count" class="text-sm text-gray-500">{priceCatalog.length} catalog items</p>
	</div>

	<div class="mt-6 grid grid-cols-1 gap-4 lg:grid-cols-[minmax(0,1fr)_240px_220px]">
		<div>
			<label for="catalog-search">Search catalog</label>
			<input id="catalog-search" type="search" placeholder="Search SKU, description, FCC ID..." autocomplete="off" />
		</div>
		<div>
			<label for="catalog-make">Make</label>
			<select id="catalog-make">
				<option value="all">All makes</option>
				{priceCatalogMakes.map((make) => <option value={make}>{make}</option>)}
			</select>
		</div>
		<div>
			<label for="catalog-worn">Worn price</label>
			<select id="catalog-worn">
				<option value="all">All items</option>
				<option value="has-worn">Has worn price</option>
				<option value="no-worn">No worn price</option>
			</select>
		</div>
	</div>

	<div class="mt-6 overflow-x-auto rounded-2xl ring-1 ring-gray-200">
		<table class="min-w-full divide-y divide-gray-200 text-left text-sm">
			<thead class="bg-gray-50">
				<tr>
					<th class="px-4 py-3 font-semibold text-gray-700">SKU</th>
					<th class="px-4 py-3 font-semibold text-gray-700">Make</th>
					<th class="px-4 py-3 font-semibold text-gray-700">Description</th>
					<th class="px-4 py-3 font-semibold text-gray-700">Price</th>
					<th class="px-4 py-3 font-semibold text-gray-700">Worn</th>
				</tr>
			</thead>
			<tbody id="catalog-table-body" class="divide-y divide-gray-100 bg-white">
				{
					priceCatalog.map((item) => (
						<tr
							data-make={item.make}
							data-has-worn={item.wornPrice === null ? "false" : "true"}
							data-search={`${item.sku} ${item.make} ${item.description}`.toLowerCase()}
						>
							<td class="px-4 py-3 font-semibold text-gray-900">{item.sku}</td>
							<td class="px-4 py-3 text-gray-600">{item.make}</td>
							<td class="px-4 py-3 text-gray-600">{item.description}</td>
							<td class="px-4 py-3 text-gray-900">${item.price.toFixed(2)}</td>
							<td class="px-4 py-3 text-gray-900">{item.wornPrice === null ? "-" : `$${item.wornPrice.toFixed(2)}`}</td>
						</tr>
					))
				}
			</tbody>
		</table>
	</div>
</section>

<script>
	document.addEventListener("astro:page-load", () => {
		const searchField = document.getElementById("catalog-search");
		const makeField = document.getElementById("catalog-make");
		const wornField = document.getElementById("catalog-worn");
		const tableBody = document.getElementById("catalog-table-body");
		const resultsCount = document.getElementById("catalog-results-count");

		if (
			!(
				searchField instanceof HTMLInputElement &&
				makeField instanceof HTMLSelectElement &&
				wornField instanceof HTMLSelectElement &&
				tableBody instanceof HTMLElement &&
				resultsCount instanceof HTMLElement
			)
		) {
			return;
		}

		const rows = Array.from(tableBody.querySelectorAll("tr"));

		const applyFilters = () => {
			const searchValue = searchField.value.trim().toLowerCase();
			const makeValue = makeField.value;
			const wornValue = wornField.value;
			let visibleCount = 0;

			rows.forEach((row) => {
				const matchesSearch = searchValue.length === 0 || (row.dataset.search ?? "").includes(searchValue);
				const matchesMake = makeValue === "all" || row.dataset.make === makeValue;
				const hasWorn = row.dataset.hasWorn === "true";
				const matchesWorn =
					wornValue === "all" ||
					(wornValue === "has-worn" && hasWorn) ||
					(wornValue === "no-worn" && !hasWorn);
				const visible = matchesSearch && matchesMake && matchesWorn;

				row.style.display = visible ? "" : "none";
				if (visible) {
					visibleCount += 1;
				}
			});

			resultsCount.textContent = `${visibleCount} matching catalog item${visibleCount === 1 ? "" : "s"}`;
		};

		searchField.addEventListener("input", applyFilters);
		makeField.addEventListener("change", applyFilters);
		wornField.addEventListener("change", applyFilters);
		applyFilters();
	});
</script>

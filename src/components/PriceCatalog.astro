---
import { getPriceCatalog, getPriceCatalogMakes } from "~/data/priceCatalog";
import KeyProductImage from "./KeyProductImage.astro";

const {
	title = "Browse the key catalog",
	description = "Filter by make, search by SKU or FCC ID, and pick the key that matches what you have.",
	scrollClass = "max-h-[70rem]",
} = Astro.props;

const priceCatalog = await getPriceCatalog();
const priceCatalogMakes = await getPriceCatalogMakes();
---

<section id="price-catalog" class="rounded-3xl bg-white p-6 shadow-sm ring-1 ring-gray-100 lg:p-8">
	<div class="flex flex-col gap-6 lg:flex-row lg:items-end lg:justify-between">
		<div class="max-w-3xl">
			<p class="text-sm font-semibold uppercase tracking-[0.2em] text-sky-700">Price list</p>
			<h2 class="mt-2 text-3xl font-bold">{title}</h2>
			<p class="mt-3 text-gray-600">{description}</p>
		</div>
		<div class="rounded-2xl bg-slate-50 px-4 py-3 ring-1 ring-slate-200">
			<p class="text-xs font-semibold uppercase tracking-[0.16em] text-sky-800">Browse results</p>
			<p id="catalog-results-count" class="mt-1 text-sm text-gray-700">{priceCatalog.length} catalog items</p>
		</div>
	</div>

	<div class="mt-6 grid grid-cols-1 gap-4 lg:grid-cols-[240px_minmax(0,1fr)_220px]">
		<div>
			<label for="catalog-make">Make</label>
			<select id="catalog-make">
				<option value="">Select a make</option>
				<option value="all">All makes</option>
				{priceCatalogMakes.map((make) => <option value={make}>{make}</option>)}
			</select>
		</div>
		<div>
			<label for="catalog-search">Search catalog</label>
			<input id="catalog-search" type="search" placeholder="Search SKU, description, FCC ID..." autocomplete="off" />
		</div>
		<div>
			<label for="catalog-worn">Condition pricing</label>
			<select id="catalog-worn">
				<option value="all">All items</option>
				<option value="has-worn">Has condition prices</option>
				<option value="no-worn">No condition prices</option>
			</select>
		</div>
	</div>

	<div class="mt-4 grid grid-cols-1 gap-4 lg:max-w-[240px]">
		<div>
			<label for="catalog-sort">Sort by price</label>
			<select id="catalog-sort">
				<option value="featured">Featured order</option>
				<option value="price-asc">Price: low to high</option>
				<option value="price-desc">Price: high to low</option>
			</select>
		</div>
	</div>

	<div class:list={["mt-6 overflow-y-auto rounded-3xl border border-gray-200 bg-gray-50 p-3 pr-2", scrollClass]}>
		<div id="catalog-card-grid" class="grid grid-cols-1 gap-5 md:grid-cols-2 xl:grid-cols-3">
			{
				priceCatalog.map((item) => (
					<article
						class="rounded-3xl border border-gray-200 bg-white p-4 shadow-sm transition hover:-translate-y-0.5 hover:shadow-md"
						data-make={item.make}
						data-has-worn={item.lightScratchesPrice === null && item.wornPrice === null ? "false" : "true"}
						data-search={`${item.sku} ${item.make} ${item.description}`.toLowerCase()}
						data-price={item.price}
						data-inventory-count={item.inventoryCount}
						data-max-order-quantity={item.maxOrderQuantity}
					>
						<KeyProductImage imageUrl={item.imageUrl} alt={`${item.make} ${item.sku} key`} />
						<div class="mt-4 space-y-4">
							<div>
								<div>
									<p class="text-xs font-semibold uppercase tracking-[0.15em] text-sky-700">{item.make}</p>
									<h3 class="mt-1 text-base font-bold text-gray-900 sm:text-lg">{item.sku}</h3>
								</div>
							</div>
							<p class="text-sm leading-5 text-gray-600">{item.description}</p>
							<div class="grid grid-cols-1 gap-2 sm:grid-cols-3">
								<button
									type="button"
									class="group rounded-2xl border border-gray-200 bg-gray-50 px-3 py-3 text-left transition hover:border-gray-900 hover:bg-gray-900 hover:text-white focus:border-gray-900 focus:bg-gray-900 focus:text-white focus:outline-none"
									data-select-sku={item.sku}
									data-select-condition="excellent"
								>
									<span class="block text-[11px] font-semibold uppercase tracking-[0.14em] text-gray-500 transition group-hover:text-white group-focus:text-white">Excellent</span>
									<span class="mt-1 block text-sm font-bold text-gray-900 transition group-hover:text-white group-focus:text-white">${item.price.toFixed(2)}</span>
								</button>
								<button
									type="button"
									class="group rounded-2xl border border-gray-200 bg-gray-50 px-3 py-3 text-left transition hover:border-gray-900 hover:bg-gray-900 hover:text-white focus:border-gray-900 focus:bg-gray-900 focus:text-white focus:outline-none"
									data-select-sku={item.sku}
									data-select-condition="light-scratches"
								>
									<span class="block text-[11px] font-semibold uppercase tracking-[0.14em] text-gray-500 transition group-hover:text-white group-focus:text-white">
										Light scratches
									</span>
									<span class="mt-1 block text-sm font-bold text-gray-900 transition group-hover:text-white group-focus:text-white">
										${(item.lightScratchesPrice ?? item.price).toFixed(2)}
									</span>
								</button>
								<button
									type="button"
									class="group rounded-2xl border border-gray-200 bg-gray-50 px-3 py-3 text-left transition hover:border-gray-900 hover:bg-gray-900 hover:text-white focus:border-gray-900 focus:bg-gray-900 focus:text-white focus:outline-none"
									data-select-sku={item.sku}
									data-select-condition="worn"
								>
									<span class="block text-[11px] font-semibold uppercase tracking-[0.14em] text-gray-500 transition group-hover:text-white group-focus:text-white">Worn</span>
									<span class="mt-1 block text-sm font-bold text-gray-900 transition group-hover:text-white group-focus:text-white">
										${(item.wornPrice ?? item.price).toFixed(2)}
									</span>
								</button>
							</div>
						</div>
					</article>
				))
			}
		</div>
	</div>
</section>

<script>
	document.addEventListener("astro:page-load", () => {
		const searchField = document.getElementById("catalog-search");
		const makeField = document.getElementById("catalog-make");
		const wornField = document.getElementById("catalog-worn");
		const sortField = document.getElementById("catalog-sort");
		const cardGrid = document.getElementById("catalog-card-grid");
		const resultsCount = document.getElementById("catalog-results-count");

		if (
			!(
				searchField instanceof HTMLInputElement &&
				makeField instanceof HTMLSelectElement &&
				wornField instanceof HTMLSelectElement &&
				sortField instanceof HTMLSelectElement &&
				cardGrid instanceof HTMLElement &&
				resultsCount instanceof HTMLElement
			)
		) {
			return;
		}

		const cards = Array.from(cardGrid.querySelectorAll("article"));
		const url = new URL(window.location.href);
		const makeParam = url.searchParams.get("make");
		if (makeParam && Array.from(makeField.options).some((option) => option.value === makeParam)) {
			makeField.value = makeParam;
		}

		const sortCards = () => {
			const sortedCards = [...cards];
			const sortValue = sortField.value;

			if (sortValue === "price-asc" || sortValue === "price-desc") {
				sortedCards.sort((left, right) => {
					const leftPrice = Number(left.dataset.price ?? "0");
					const rightPrice = Number(right.dataset.price ?? "0");
					return sortValue === "price-asc" ? leftPrice - rightPrice : rightPrice - leftPrice;
				});
			}

			sortedCards.forEach((card) => {
				cardGrid.appendChild(card);
			});
		};

		const applyFilters = () => {
			const searchValue = searchField.value.trim().toLowerCase();
			const makeValue = makeField.value;
			const wornValue = wornField.value;
			const showAllMakes = makeValue === "all";
			const hasSelectedMake = makeValue.length > 0 && makeValue !== "all";
			let visibleCount = 0;

			cards.forEach((card) => {
				const hasSearch = searchValue.length > 0;
				const matchesSearch = !hasSearch || (card.dataset.search ?? "").includes(searchValue);
				const matchesMake = !hasSelectedMake || card.dataset.make === makeValue;
				const hasWorn = card.dataset.hasWorn === "true";
				const matchesWorn =
					wornValue === "all" ||
					(wornValue === "has-worn" && hasWorn) ||
					(wornValue === "no-worn" && !hasWorn);
				const visible = (showAllMakes || hasSelectedMake || hasSearch) && matchesSearch && matchesMake && matchesWorn;

				card.style.display = visible ? "" : "none";
				if (visible) {
					visibleCount += 1;
				}
			});

			sortCards();

			if (hasSelectedMake) {
				resultsCount.textContent = `${visibleCount} matching catalog item${visibleCount === 1 ? "" : "s"}`;
				return;
			}

			if (showAllMakes) {
				resultsCount.textContent = `${visibleCount} catalog item${visibleCount === 1 ? "" : "s"} across all makes`;
				return;
			}

			resultsCount.textContent = searchValue
				? `${visibleCount} matching catalog item${visibleCount === 1 ? "" : "s"} across all makes`
				: "Choose a make or select All makes to browse the full catalog";
		};

		const updateSelectedCardButton = (selectedButton) => {
			cardGrid.querySelectorAll("[data-select-sku]").forEach((button) => {
				const isActive = button === selectedButton;
				button.setAttribute("aria-pressed", isActive ? "true" : "false");
				button.classList.toggle("border-gray-900", isActive);
				button.classList.toggle("bg-gray-900", isActive);
				button.classList.toggle("text-white", isActive);
				button.classList.toggle("shadow-sm", isActive);

				button.querySelectorAll("span").forEach((label) => {
					label.classList.toggle("text-white", isActive);
					label.classList.toggle("text-gray-500", !isActive && label.classList.contains("uppercase"));
					label.classList.toggle("text-gray-900", !isActive && !label.classList.contains("uppercase"));
				});
			});
		};

		cardGrid.querySelectorAll("[data-select-sku]").forEach((button) => {
			button.addEventListener("click", () => {
				const sku = button.getAttribute("data-select-sku");
				const condition = button.getAttribute("data-select-condition");
				if (!sku) {
					return;
				}

				updateSelectedCardButton(button);

				document.dispatchEvent(
					new CustomEvent("key-catalog-select", {
						detail: { sku, condition },
					})
				);
			});
		});

		searchField.addEventListener("input", applyFilters);
		makeField.addEventListener("change", applyFilters);
		wornField.addEventListener("change", applyFilters);
		sortField.addEventListener("change", applyFilters);
		applyFilters();
	});
</script>

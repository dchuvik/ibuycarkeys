---
import { priceCatalog } from "~/data/priceCatalog";
import PriceCatalog from "../PriceCatalog.astro";
---

<section class="space-y-8">
	<form
		name="quote-cart"
		method="POST"
		data-netlify="true"
		netlify-honeypot="bot-field"
		class="hidden"
		aria-hidden="true"
	>
		<input type="hidden" name="form-name" value="quote-cart" />
		<input type="text" name="bot-field" />
		<input type="text" name="recipient" value="dchuvik@gmail.com" />
		<textarea name="quote_summary"></textarea>
		<input type="text" name="total_keys" />
		<input type="text" name="estimated_payout" />
		<input type="text" name="submitted_at" />
		<input type="text" name="source_page" />
	</form>

	<div class="rounded-3xl bg-white p-6 shadow-xl ring-1 ring-gray-100 lg:p-8">
		<div class="mb-6">
			<p class="text-sm font-semibold uppercase tracking-[0.2em] text-amber-700">Build your quote</p>
			<h2 class="mt-2 text-3xl font-bold text-balance">Search for your key and see your payout</h2>
			<p class="mt-3 text-base text-gray-600">
				Use the catalog below to find your key, then review the payout, choose the condition if available, and
				add it to your quote cart.
			</p>
		</div>

		<form id="key-quote-form" class="space-y-5">
			<div class="space-y-5">
				<PriceCatalog scrollClass="max-h-[56rem]" />

				<div class="grid grid-cols-1 gap-5 xl:grid-cols-2">
					<div id="current-line-payout" class="rounded-3xl bg-amber-50 p-5 ring-1 ring-amber-100 lg:p-6">
						<div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
							<div>
								<p class="text-sm font-semibold uppercase tracking-[0.18em] text-amber-800">Current line payout</p>
								<h3 class="mt-2 text-2xl font-bold text-gray-900">Review this key</h3>
								<p id="quote-preview-detail" class="mt-2 text-sm text-gray-600">
									Select a key from the catalog above to see your estimated payout.
								</p>
							</div>
							<div class="rounded-2xl bg-white px-4 py-3 text-left shadow-sm ring-1 ring-amber-100 sm:min-w-44">
								<p class="text-xs font-semibold uppercase tracking-[0.18em] text-gray-500">Estimated line total</p>
								<p id="quote-preview-total" class="mt-2 text-4xl font-bold text-gray-900">$0.00</p>
							</div>
						</div>

						<div id="quote-preview-selection" class="mt-5 rounded-2xl border border-amber-200 bg-white/80 p-4">
							<p class="text-xs font-semibold uppercase tracking-[0.15em] text-gray-500">Selected key</p>
							<p id="quote-preview-sku" class="mt-2 text-lg font-bold text-gray-900">No key selected yet</p>
							<p id="quote-preview-make" class="mt-1 text-sm font-semibold text-amber-800"></p>
						</div>

						<div class="mt-5 grid grid-cols-1 gap-5 sm:grid-cols-2">
							<div id="price-condition-group">
								<label id="price-condition-label" for="price-condition">Condition</label>
								<select id="price-condition" name="condition">
									<option value="standard">Standard</option>
									<option value="worn">Worn</option>
								</select>
								<p id="price-condition-help" class="mt-2 text-sm text-gray-500">
									Choose the condition that best matches your key.
								</p>
							</div>

							<div>
								<label for="key-quantity">How many keys?</label>
								<input id="key-quantity" name="quantity" type="number" min="1" step="1" value="1" required />
							</div>
						</div>

						<div class="mt-5 flex flex-col gap-3 sm:flex-row sm:items-center">
							<button
								type="submit"
								class="button button-black min-h-12 w-full rounded-full px-5 sm:w-auto"
							>
								Add To Quote Cart
							</button>
							<button
								id="add-more-keys"
								type="button"
								class="button button-white min-h-12 w-full rounded-full border border-gray-200 px-5 sm:w-auto"
							>
								Add More Keys
							</button>
							<button
								id="reset-key-form"
								type="button"
								class="button button-yellow min-h-12 w-full rounded-full px-5 sm:w-auto"
							>
								Clear This Key
							</button>
							<p class="text-sm text-gray-600">Select a key first, then choose the condition and quantity here.</p>
						</div>
					</div>

					<div class="rounded-3xl bg-gray-900 p-6 text-white shadow-xl">
						<div class="flex items-start justify-between gap-4">
							<div>
								<p class="text-sm font-semibold uppercase tracking-[0.2em] text-amber-300">Quote cart</p>
								<h3 class="mt-2 text-2xl font-bold">Your saved keys</h3>
							</div>
							<div class="flex flex-col gap-2 sm:flex-row">
								<button
									id="send-quote-cart"
									type="button"
									class="button button-yellow min-h-11 rounded-full !px-4 !py-2 text-sm"
								>
									Send Quote
								</button>
								<button
									id="clear-quote-cart"
									type="button"
									class="button button-white min-h-11 rounded-full !px-4 !py-2 text-sm"
								>
									Clear All
								</button>
							</div>
						</div>
						<p id="send-quote-status" class="mt-3 text-sm text-gray-300"></p>

						<div class="mt-6 grid grid-cols-2 gap-4 rounded-2xl bg-white/5 p-4">
							<div>
								<p class="text-sm text-gray-300">Items</p>
								<p id="quote-cart-count" class="text-3xl font-bold">0</p>
							</div>
							<div>
								<p class="text-sm text-gray-300">Estimated payout</p>
								<p id="quote-cart-total" class="text-3xl font-bold text-amber-300">$0.00</p>
							</div>
						</div>

						<div class="mt-6 max-h-80 overflow-y-auto pr-2">
							<ul id="quote-cart-items" class="space-y-3"></ul>
							<p
								id="quote-cart-empty"
								class="rounded-2xl border border-dashed border-white/20 p-4 text-sm text-gray-300"
							>
								Your quote cart is empty. Search for a key and add it here to start building your quote.
							</p>
						</div>
					</div>
				</div>
			</div>

			<div class="hidden">
				<label for="sku-select">Matching price list item</label>
				<select id="sku-select" name="sku" required size="8" class="min-h-64">
					{
						priceCatalog.map((item) => (
							<option
								value={item.sku}
								data-make={item.make}
								data-description={item.description.toLowerCase()}
								data-price={item.price}
								data-worn-price={item.wornPrice ?? ""}
							>
								{item.sku} | {item.description}
							</option>
						))
					}
				</select>
			</div>
		</form>
	</div>
</section>

<script>
	document.addEventListener("astro:page-load", () => {
		const storageKey = "key-quote-cart";
		const currencyFormatter = new Intl.NumberFormat("en-US", {
			style: "currency",
			currency: "USD",
		});

		const form = document.getElementById("key-quote-form");
		const skuSelect = document.getElementById("sku-select");
		const conditionField = document.getElementById("price-condition");
		const conditionGroup = document.getElementById("price-condition-group");
		const conditionLabel = document.getElementById("price-condition-label");
		const conditionHelp = document.getElementById("price-condition-help");
		const quantityField = document.getElementById("key-quantity");
		const currentLinePayout = document.getElementById("current-line-payout");
		const quotePreviewTotal = document.getElementById("quote-preview-total");
		const quotePreviewDetail = document.getElementById("quote-preview-detail");
		const quotePreviewSku = document.getElementById("quote-preview-sku");
		const quotePreviewMake = document.getElementById("quote-preview-make");
		const cartList = document.getElementById("quote-cart-items");
		const cartEmpty = document.getElementById("quote-cart-empty");
		const cartCount = document.getElementById("quote-cart-count");
		const cartTotal = document.getElementById("quote-cart-total");
		const addMoreKeysButton = document.getElementById("add-more-keys");
		const resetButton = document.getElementById("reset-key-form");
		const sendQuoteCartButton = document.getElementById("send-quote-cart");
		const sendQuoteStatus = document.getElementById("send-quote-status");
		const clearCartButton = document.getElementById("clear-quote-cart");
		const priceCatalog = document.getElementById("price-catalog");

		if (
			!(
				form instanceof HTMLFormElement &&
				skuSelect instanceof HTMLSelectElement &&
				conditionField instanceof HTMLSelectElement &&
				conditionGroup instanceof HTMLElement &&
				conditionLabel instanceof HTMLElement &&
				conditionHelp instanceof HTMLElement &&
				quantityField instanceof HTMLInputElement &&
				currentLinePayout instanceof HTMLElement &&
				quotePreviewTotal instanceof HTMLElement &&
				quotePreviewDetail instanceof HTMLElement &&
				quotePreviewSku instanceof HTMLElement &&
				quotePreviewMake instanceof HTMLElement &&
				cartList instanceof HTMLElement &&
				cartEmpty instanceof HTMLElement &&
				cartCount instanceof HTMLElement &&
				cartTotal instanceof HTMLElement &&
				addMoreKeysButton instanceof HTMLButtonElement &&
				resetButton instanceof HTMLButtonElement &&
				sendQuoteCartButton instanceof HTMLButtonElement &&
				sendQuoteStatus instanceof HTMLElement &&
				clearCartButton instanceof HTMLButtonElement &&
				priceCatalog instanceof HTMLElement
			)
		) {
			return;
		}

		const readCart = () => {
			try {
				const stored = localStorage.getItem(storageKey);
				const parsed = stored ? JSON.parse(stored) : [];
				return Array.isArray(parsed) ? parsed : [];
			} catch {
				return [];
			}
		};

		const writeCart = (items) => {
			localStorage.setItem(storageKey, JSON.stringify(items));
		};

		const buildQuoteSubmission = (items) => {
			const totalQuantity = items.reduce((sum, item) => sum + item.quantity, 0);
			const totalPayout = items.reduce((sum, item) => sum + item.lineTotal, 0);
			const createdAt = new Date().toLocaleString("en-US", {
				dateStyle: "medium",
				timeStyle: "short",
			});
			const lines = items.map(
				(item, index) =>
					`${index + 1}. ${item.sku} - ${item.description} | ${item.condition} | ${item.quantity} key${
						item.quantity === 1 ? "" : "s"
					} @ ${currencyFormatter.format(item.unitPrice)} | Line total: ${currencyFormatter.format(item.lineTotal)}`
			);

			return {
				totalQuantity,
				totalPayout,
				createdAt,
				summary: [
					"Quote cart details:",
					"",
					...lines,
					"",
					`Total keys: ${totalQuantity}`,
					`Estimated payout: ${currencyFormatter.format(totalPayout)}`,
					`Created: ${createdAt}`,
				].join("\n"),
			};
		};

		const setConditionAvailability = (enabled) => {
			conditionField.disabled = !enabled;

			conditionGroup.classList.toggle("opacity-55", !enabled);
			conditionLabel.classList.toggle("text-gray-400", !enabled);
			conditionHelp.textContent = enabled
				? "Choose the condition that best matches your key."
				: "Only one payout option is available for this key.";

			if (!enabled) {
				conditionField.value = "standard";
			}
		};

		const getSelectedOption = () => {
			const selected = skuSelect.selectedOptions[0];
			if (!selected) {
				return null;
			}
			return selected;
		};

		const getCurrentQuote = () => {
			const selected = getSelectedOption();
			const quantity = Number.parseInt(quantityField.value, 10) || 0;
			const wantsWorn = conditionField.value === "worn";

			if (!selected) {
				return null;
			}

			const standardPrice = Number(selected.dataset.price ?? "0");
			const wornValue = selected.dataset.wornPrice;
			const wornPrice = wornValue ? Number(wornValue) : null;
			const unitPrice = wantsWorn && wornPrice !== null ? wornPrice : standardPrice;
			const usedCondition = wantsWorn && wornPrice !== null ? "worn" : "standard";

			return {
				sku: selected.value,
				description: selected.textContent?.split("|").slice(1).join("|").trim() ?? selected.value,
				make: selected.dataset.make ?? "Unknown",
				quantity,
				condition: usedCondition,
				unitPrice,
				lineTotal: unitPrice * quantity,
				wornAvailable: wornPrice !== null,
			};
		};

		const updatePreview = () => {
			const current = getCurrentQuote();
			const selected = getSelectedOption();
			const hasConditionOptions = Boolean(selected?.dataset.wornPrice);

			setConditionAvailability(hasConditionOptions);

			if (!current || current.quantity < 1) {
				quotePreviewTotal.textContent = currencyFormatter.format(0);
				quotePreviewDetail.textContent = "Select a key from the catalog above to see your estimated payout.";
				quotePreviewSku.textContent = "No key selected yet";
				quotePreviewMake.textContent = "";
				conditionHelp.textContent = "Choose the condition that best matches your key.";
				return;
			}

			quotePreviewTotal.textContent = currencyFormatter.format(current.lineTotal);
			quotePreviewSku.textContent = current.sku;
			quotePreviewMake.textContent = `${current.make} key`;
			quotePreviewDetail.textContent = `${current.quantity} x ${current.condition} price at ${currencyFormatter.format(
				current.unitPrice
			)} each`;
		};

		const renderCart = () => {
			const items = readCart();
			cartList.innerHTML = "";

			const totalQuantity = items.reduce((sum, item) => sum + item.quantity, 0);
			const totalPayout = items.reduce((sum, item) => sum + item.lineTotal, 0);

			cartCount.textContent = String(totalQuantity);
			cartTotal.textContent = currencyFormatter.format(totalPayout);
			cartEmpty.style.display = items.length ? "none" : "block";

			items.forEach((item) => {
				const entry = document.createElement("li");
				entry.className = "rounded-2xl bg-white/5 p-4 ring-1 ring-white/10";
				entry.innerHTML = `
					<div class="flex items-start justify-between gap-3">
						<div>
							<p class="font-semibold">${item.sku}</p>
							<p class="mt-1 text-sm text-gray-300">${item.description}</p>
							<p class="mt-1 text-sm text-gray-300">${item.condition} | ${item.quantity} key${item.quantity === 1 ? "" : "s"} at ${currencyFormatter.format(item.unitPrice)} each</p>
						</div>
						<div class="text-right">
							<p class="font-semibold text-amber-300">${currencyFormatter.format(item.lineTotal)}</p>
							<button type="button" class="mt-2 text-sm text-white underline decoration-white/30 underline-offset-4" data-remove-id="${item.id}">
								Remove
							</button>
						</div>
					</div>
				`;
				cartList.appendChild(entry);
			});

			cartList.querySelectorAll("[data-remove-id]").forEach((button) => {
				button.addEventListener("click", () => {
					const nextItems = readCart().filter((item) => item.id !== button.getAttribute("data-remove-id"));
					writeCart(nextItems);
					renderCart();
				});
			});
		};

		skuSelect.addEventListener("change", updatePreview);
		conditionField.addEventListener("change", updatePreview);
		quantityField.addEventListener("input", updatePreview);
		document.addEventListener("key-catalog-select", (event) => {
			const customEvent = event as CustomEvent<{ sku?: string }>;
			const selectedSku = customEvent.detail?.sku;
			if (!selectedSku) {
				return;
			}

			const matchingOption = Array.from(skuSelect.options).find((option) => option.value === selectedSku);
			if (!matchingOption) {
				return;
			}

			skuSelect.value = selectedSku;
			skuSelect.dispatchEvent(new Event("change"));
			currentLinePayout.scrollIntoView({ block: "start", behavior: "smooth" });
		});

		form.addEventListener("submit", (event) => {
			event.preventDefault();
			const current = getCurrentQuote();

			if (!current || current.quantity < 1) {
				updatePreview();
				return;
			}

			const nextItems = [
				...readCart(),
				{
					id: crypto.randomUUID(),
					...current,
					createdAt: new Date().toISOString(),
				},
			];

			writeCart(nextItems);
			renderCart();
			quantityField.value = "1";
			updatePreview();
		});

		resetButton.addEventListener("click", () => {
			conditionField.value = "standard";
			quantityField.value = "1";
			updatePreview();
		});

		addMoreKeysButton.addEventListener("click", () => {
			priceCatalog.scrollIntoView({ block: "start", behavior: "smooth" });
		});

		clearCartButton.addEventListener("click", () => {
			writeCart([]);
			renderCart();
			sendQuoteStatus.textContent = "";
		});

		sendQuoteCartButton.addEventListener("click", async () => {
			const items = readCart();
			if (!items.length) {
				sendQuoteStatus.textContent = "Add at least one key to your quote before sending.";
				return;
			}

			const submission = buildQuoteSubmission(items);
			const payload = new URLSearchParams({
				"form-name": "quote-cart",
				recipient: "dchuvik@gmail.com",
				quote_summary: submission.summary,
				total_keys: String(submission.totalQuantity),
				estimated_payout: currencyFormatter.format(submission.totalPayout),
				submitted_at: submission.createdAt,
				source_page: window.location.href,
			});

			sendQuoteCartButton.disabled = true;
			sendQuoteStatus.textContent = "Sending your quote...";

			try {
				const response = await fetch("/", {
					method: "POST",
					headers: { "Content-Type": "application/x-www-form-urlencoded" },
					body: payload.toString(),
				});

				if (!response.ok) {
					throw new Error("Submission failed");
				}

				sendQuoteStatus.textContent = "Your quote was sent successfully.";
			} catch {
				sendQuoteStatus.textContent = "Your quote could not be sent right now. Please try again.";
			} finally {
				sendQuoteCartButton.disabled = false;
			}
		});

		skuSelect.selectedIndex = -1;
		updatePreview();
		renderCart();
	});
</script>

---
import { getPriceCatalog } from "~/data/priceCatalog";
import PriceCatalog from "../PriceCatalog.astro";

const priceCatalog = await getPriceCatalog();
---

<section class="space-y-8">
	<form
		id="quote-request-form"
		name="quote-cart"
		method="POST"
		class="fixed inset-0 z-50 hidden items-center justify-center bg-gray-950/70 p-4"
	>
		<div class="absolute inset-0" data-close-quote-request></div>
		<div class="relative z-10 w-full max-w-2xl max-h-[84vh] overflow-y-auto rounded-[2rem] bg-white p-5 shadow-2xl ring-1 ring-gray-200">
			<div class="flex items-start justify-between gap-4">
				<div>
					<p class="text-sm font-semibold uppercase tracking-[0.2em] text-sky-700">Submit your quote</p>
					<h3 class="mt-2 text-xl font-bold text-gray-900">Submit your quote details</h3>
					<p class="mt-2 text-sm leading-6 text-gray-600">
						Add your contact and mailing details so we can review your shipment and process your payout.
					</p>
				</div>
				<button
					type="button"
					data-close-quote-request
					class="inline-flex size-11 items-center justify-center rounded-full border border-gray-200 text-xl leading-none text-gray-500 transition hover:border-gray-300 hover:text-gray-700"
					aria-label="Close quote form"
				>
					&times;
				</button>
			</div>

			<input type="hidden" name="bot-field" />
			<input type="hidden" name="total_keys" id="quote-request-total-keys" />
			<input type="hidden" name="estimated_payout" id="quote-request-estimated-payout" />
			<input type="hidden" name="submitted_at" id="quote-request-submitted-at" />
			<input type="hidden" name="source_page" id="quote-request-source-page" />
			<input type="hidden" name="client_timezone" id="quote-request-client-timezone" />
			<input type="hidden" name="client_utc_offset_minutes" id="quote-request-client-utc-offset" />
			<input type="hidden" name="quote_items_json" id="quote-request-items-json" />

			<div class="mt-4 grid grid-cols-1 gap-3 sm:grid-cols-2">
				<div>
					<label for="quote-request-name">Your name</label>
					<input id="quote-request-name" name="customer_name" type="text" autocomplete="name" required />
				</div>
				<div>
					<label for="quote-request-email">Email address</label>
					<input
						id="quote-request-email"
						name="customer_email"
						type="email"
						autocomplete="email"
						required
					/>
				</div>
				<div class="sm:col-span-2">
					<label for="quote-request-phone">Phone number</label>
					<input
						id="quote-request-phone"
						name="customer_phone"
						type="tel"
						autocomplete="tel"
						inputmode="tel"
						placeholder="(555) 555-5555"
						required
					/>
				</div>
				<div class="sm:col-span-2">
					<label for="quote-request-address">Mailing address for payment</label>
					<input
						id="quote-request-address"
						name="customer_address"
						type="text"
						autocomplete="street-address"
						placeholder="Street address"
						required
					/>
				</div>
				<div>
					<label for="quote-request-city">City</label>
					<input id="quote-request-city" name="customer_city" type="text" autocomplete="address-level2" required />
				</div>
				<div>
					<label for="quote-request-state">State</label>
					<input
						id="quote-request-state"
						name="customer_state"
						type="text"
						autocomplete="address-level1"
						maxlength="2"
						placeholder="NY"
						required
					/>
				</div>
				<div>
					<label for="quote-request-zip">ZIP code</label>
					<input
						id="quote-request-zip"
						name="customer_zip"
						type="text"
						autocomplete="postal-code"
						inputmode="numeric"
						placeholder="12345"
						required
					/>
				</div>
				<div class="sm:col-span-2">
					<label for="quote-request-summary">Quote details</label>
					<textarea
						id="quote-request-summary"
						name="quote_summary"
						rows="5"
						readonly
						class="min-h-36 resize-none"
					></textarea>
				</div>
			</div>

			<div class="mt-4 rounded-2xl bg-slate-50 px-4 py-3 text-sm leading-5 text-slate-900 ring-1 ring-slate-200">
				You confirm you own these keys. If the total changes after inspection, we will contact you before payment.
			</div>

			<p id="quote-request-status" class="mt-4 text-sm text-gray-600"></p>

			<div class="mt-4 flex flex-col gap-3 sm:flex-row sm:justify-end">
				<button
					type="button"
					data-close-quote-request
					class="button button-white min-h-12 rounded-full border border-gray-200 px-5"
				>
					Cancel
				</button>
				<button type="submit" class="button button-black min-h-12 rounded-full px-5">
					Submit Quote
				</button>
			</div>
		</div>
	</form>

	<div
		id="quote-submission-toast"
		class="pointer-events-none fixed inset-x-4 bottom-4 z-50 hidden justify-center sm:inset-x-auto sm:right-6 sm:justify-end"
	>
		<div class="max-w-md rounded-2xl bg-emerald-600 px-5 py-4 text-sm font-semibold text-white shadow-2xl ring-1 ring-emerald-500/40">
			Your quote was submitted successfully.
		</div>
	</div>

	<div
		id="quote-cart-feedback-toast"
		class="pointer-events-none fixed inset-x-4 bottom-4 z-50 hidden justify-center sm:inset-x-auto sm:right-6 sm:justify-end"
	>
		<div
			id="quote-cart-feedback"
			class="max-w-md rounded-2xl bg-gray-900 px-5 py-4 text-sm font-semibold text-white shadow-2xl ring-1 ring-gray-800/60"
		></div>
	</div>

	<div class="rounded-3xl bg-white p-6 shadow-xl ring-1 ring-gray-100 lg:p-8">
		<div class="mb-6">
			<p class="text-sm font-semibold uppercase tracking-[0.2em] text-sky-700">Build your quote</p>
			<h2 class="mt-2 text-3xl font-bold text-balance">Search for your key and see your payout</h2>
			<p class="mt-3 text-base text-gray-600">
				Use the catalog below to find your key, then review the payout, choose the condition if available, and
				add it to your quote cart.
			</p>
		</div>

		<form id="key-quote-form" class="space-y-5">
			<div class="space-y-5">
				<PriceCatalog scrollClass="max-h-[56rem]" />

				<div class="grid grid-cols-1 gap-5 xl:grid-cols-2">
					<div id="current-line-payout" class="rounded-3xl bg-slate-50 p-5 ring-1 ring-slate-200 lg:p-6">
						<div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
							<div>
								<p class="text-sm font-semibold uppercase tracking-[0.18em] text-sky-800">Current line payout</p>
								<h3 class="mt-2 text-2xl font-bold text-gray-900">Review this key</h3>
								<p id="quote-preview-detail" class="mt-2 text-sm text-gray-600">
									Select a key from the catalog above to see your estimated payout.
								</p>
							</div>
							<div class="rounded-2xl bg-white px-4 py-3 text-left shadow-sm ring-1 ring-slate-200 sm:min-w-44">
								<p class="text-xs font-semibold uppercase tracking-[0.18em] text-gray-500">Estimated line total</p>
								<p id="quote-preview-total" class="mt-2 text-4xl font-bold text-gray-900">$0.00</p>
							</div>
						</div>

						<div id="quote-preview-selection" class="mt-5 rounded-2xl border border-slate-200 bg-white/80 p-4">
							<p class="text-xs font-semibold uppercase tracking-[0.15em] text-gray-500">Selected key</p>
							<p id="quote-preview-sku" class="mt-2 text-lg font-bold text-gray-900">No key selected yet</p>
							<p id="quote-preview-make" class="mt-1 text-sm font-semibold text-sky-800"></p>
							<p id="quote-preview-inventory" class="mt-2 text-sm text-gray-600"></p>
						</div>

						<div class="mt-5 grid grid-cols-1 gap-5 sm:grid-cols-2">
							<div id="price-condition-group">
								<label id="price-condition-label" for="price-condition">Condition</label>
								<select id="price-condition" name="condition">
									<option value="excellent">Excellent</option>
									<option value="light-scratches">Light scratches</option>
									<option value="worn">Worn</option>
								</select>
								<p id="price-condition-help" class="mt-2 text-sm text-gray-500">
									Choose the condition that best matches the key you are sending in.
								</p>
							</div>

							<div>
								<label for="key-quantity">How many keys?</label>
								<input id="key-quantity" name="quantity" type="number" min="1" step="1" value="1" required />
							</div>
						</div>

						<div class="mt-5 flex flex-col gap-3 sm:flex-row sm:items-center">
							<button
								type="submit"
								class="button button-black min-h-12 w-full rounded-full px-5 sm:w-auto"
							>
								Add To Quote Cart
							</button>
							<button
								id="add-more-keys"
								type="button"
								class="button button-white min-h-12 w-full rounded-full border border-gray-200 px-5 sm:w-auto"
							>
								Add More Keys
							</button>
							<button
								id="reset-key-form"
								type="button"
								class="button button-yellow min-h-12 w-full rounded-full px-5 sm:w-auto"
							>
								Clear This Key
							</button>
							<p class="text-sm text-gray-600">Select a key first, then choose the condition and quantity here.</p>
						</div>
					</div>

					<div class="rounded-3xl bg-gray-900 p-6 text-white shadow-xl">
						<div class="flex items-start justify-between gap-4">
							<div>
								<p class="text-sm font-semibold uppercase tracking-[0.2em] text-sky-300">Quote cart</p>
								<h3 class="mt-2 text-2xl font-bold">Your saved keys</h3>
							</div>
							<div class="flex flex-col gap-2 sm:flex-row">
								<button
									id="send-quote-cart"
									type="button"
									class="button button-yellow min-h-11 rounded-full !px-4 !py-2 text-sm"
								>
									Send Quote
								</button>
								<button
									id="clear-quote-cart"
									type="button"
									class="button button-white min-h-11 rounded-full !px-4 !py-2 text-sm"
								>
									Clear All
								</button>
							</div>
						</div>
						<p id="send-quote-status" class="mt-3 text-sm text-gray-300"></p>

						<div class="mt-6 grid grid-cols-2 gap-4 rounded-2xl bg-white/5 p-4">
							<div>
								<p class="text-sm text-gray-300">Items</p>
								<p id="quote-cart-count" class="text-3xl font-bold">0</p>
							</div>
							<div>
								<p class="text-sm text-gray-300">Estimated payout</p>
								<p id="quote-cart-total" class="text-3xl font-bold text-sky-300">$0.00</p>
							</div>
						</div>

						<div class="mt-6 max-h-80 overflow-y-auto pr-2">
							<ul id="quote-cart-items" class="space-y-3"></ul>
							<p
								id="quote-cart-empty"
								class="rounded-2xl border border-dashed border-white/20 p-4 text-sm text-gray-300"
							>
								Your quote cart is empty. Search for a key and add it here to start building your quote.
							</p>
						</div>
					</div>
				</div>
			</div>

			<div class="hidden">
				<label for="sku-select">Matching price list item</label>
				<select id="sku-select" name="sku" required size="8" class="min-h-64">
					{
						priceCatalog.map((item) => (
							<option
								value={item.sku}
								data-make={item.make}
								data-description={item.description.toLowerCase()}
								data-description-label={item.description}
								data-price={item.price}
								data-light-scratches-price={item.lightScratchesPrice ?? ""}
								data-worn-price={item.wornPrice ?? ""}
								data-inventory-count={item.inventoryCount}
								data-max-order-quantity={item.maxOrderQuantity}
							>
								{item.sku} | {item.description}
							</option>
						))
					}
				</select>
			</div>
		</form>
	</div>
</section>

<script>
	document.addEventListener("astro:page-load", () => {
		const storageKey = "key-quote-cart";
		const currencyFormatter = new Intl.NumberFormat("en-US", {
			style: "currency",
			currency: "USD",
		});

		const form = document.getElementById("key-quote-form");
		const skuSelect = document.getElementById("sku-select");
		const conditionField = document.getElementById("price-condition");
		const conditionGroup = document.getElementById("price-condition-group");
		const conditionLabel = document.getElementById("price-condition-label");
		const conditionHelp = document.getElementById("price-condition-help");
		const quantityField = document.getElementById("key-quantity");
		const currentLinePayout = document.getElementById("current-line-payout");
		const quotePreviewTotal = document.getElementById("quote-preview-total");
		const quotePreviewDetail = document.getElementById("quote-preview-detail");
		const quotePreviewSku = document.getElementById("quote-preview-sku");
		const quotePreviewMake = document.getElementById("quote-preview-make");
		const quotePreviewInventory = document.getElementById("quote-preview-inventory");
		const cartList = document.getElementById("quote-cart-items");
		const cartEmpty = document.getElementById("quote-cart-empty");
		const cartCount = document.getElementById("quote-cart-count");
		const cartTotal = document.getElementById("quote-cart-total");
		const quoteCartPanel = cartList.closest(".rounded-3xl.bg-gray-900");
		const addMoreKeysButton = document.getElementById("add-more-keys");
		const resetButton = document.getElementById("reset-key-form");
		const sendQuoteCartButton = document.getElementById("send-quote-cart");
		const sendQuoteStatus = document.getElementById("send-quote-status");
		const clearCartButton = document.getElementById("clear-quote-cart");
		const priceCatalogSection = document.getElementById("price-catalog");
		const quoteRequestForm = document.getElementById("quote-request-form");
		const quoteRequestName = document.getElementById("quote-request-name");
		const quoteRequestEmail = document.getElementById("quote-request-email");
		const quoteRequestPhone = document.getElementById("quote-request-phone");
		const quoteRequestAddress = document.getElementById("quote-request-address");
		const quoteRequestCity = document.getElementById("quote-request-city");
		const quoteRequestState = document.getElementById("quote-request-state");
		const quoteRequestZip = document.getElementById("quote-request-zip");
		const quoteRequestSummary = document.getElementById("quote-request-summary");
		const quoteRequestTotalKeys = document.getElementById("quote-request-total-keys");
		const quoteRequestEstimatedPayout = document.getElementById("quote-request-estimated-payout");
		const quoteRequestSubmittedAt = document.getElementById("quote-request-submitted-at");
		const quoteRequestSourcePage = document.getElementById("quote-request-source-page");
		const quoteRequestClientTimezone = document.getElementById("quote-request-client-timezone");
		const quoteRequestClientUtcOffset = document.getElementById("quote-request-client-utc-offset");
		const quoteRequestStatus = document.getElementById("quote-request-status");
		const quoteRequestItemsJson = document.getElementById("quote-request-items-json");
		const closeQuoteRequestButtons = Array.from(document.querySelectorAll("[data-close-quote-request]"));
		const quoteCartFeedback = document.getElementById("quote-cart-feedback");
		const quoteCartFeedbackToast = document.getElementById("quote-cart-feedback-toast");
		const quoteSubmissionToast = document.getElementById("quote-submission-toast");
		let quoteCartFeedbackTimer = 0;
		let quoteSubmissionToastTimer = 0;

		if (
			!(
				form instanceof HTMLFormElement &&
				skuSelect instanceof HTMLSelectElement &&
				conditionField instanceof HTMLSelectElement &&
				conditionGroup instanceof HTMLElement &&
				conditionLabel instanceof HTMLElement &&
				conditionHelp instanceof HTMLElement &&
				quantityField instanceof HTMLInputElement &&
				currentLinePayout instanceof HTMLElement &&
				quotePreviewTotal instanceof HTMLElement &&
				quotePreviewDetail instanceof HTMLElement &&
				quotePreviewSku instanceof HTMLElement &&
				quotePreviewMake instanceof HTMLElement &&
				quotePreviewInventory instanceof HTMLElement &&
				cartList instanceof HTMLElement &&
				cartEmpty instanceof HTMLElement &&
				cartCount instanceof HTMLElement &&
				cartTotal instanceof HTMLElement &&
				quoteCartPanel instanceof HTMLElement &&
				addMoreKeysButton instanceof HTMLButtonElement &&
				resetButton instanceof HTMLButtonElement &&
				sendQuoteCartButton instanceof HTMLButtonElement &&
				sendQuoteStatus instanceof HTMLElement &&
				clearCartButton instanceof HTMLButtonElement &&
				priceCatalogSection instanceof HTMLElement &&
				quoteRequestForm instanceof HTMLFormElement &&
				quoteRequestName instanceof HTMLInputElement &&
				quoteRequestEmail instanceof HTMLInputElement &&
				quoteRequestPhone instanceof HTMLInputElement &&
				quoteRequestAddress instanceof HTMLInputElement &&
				quoteRequestCity instanceof HTMLInputElement &&
				quoteRequestState instanceof HTMLInputElement &&
				quoteRequestZip instanceof HTMLInputElement &&
				quoteRequestSummary instanceof HTMLTextAreaElement &&
				quoteRequestTotalKeys instanceof HTMLInputElement &&
				quoteRequestEstimatedPayout instanceof HTMLInputElement &&
				quoteRequestSubmittedAt instanceof HTMLInputElement &&
				quoteRequestSourcePage instanceof HTMLInputElement &&
				quoteRequestClientTimezone instanceof HTMLInputElement &&
				quoteRequestClientUtcOffset instanceof HTMLInputElement &&
				quoteRequestStatus instanceof HTMLElement &&
				quoteRequestItemsJson instanceof HTMLInputElement &&
				quoteCartFeedback instanceof HTMLElement &&
				quoteCartFeedbackToast instanceof HTMLElement &&
				quoteSubmissionToast instanceof HTMLElement
			)
		) {
			return;
		}

		const openQuoteRequest = () => {
			quoteRequestForm.classList.remove("hidden");
			quoteRequestForm.classList.add("flex");
			document.body.classList.add("overflow-hidden");
		};

		const closeQuoteRequest = () => {
			quoteRequestForm.classList.add("hidden");
			quoteRequestForm.classList.remove("flex");
			quoteRequestStatus.textContent = "";
			document.body.classList.remove("overflow-hidden");
		};

		const showQuoteCartFeedback = (message) => {
			quoteCartFeedback.textContent = message;
			quoteCartFeedbackToast.classList.remove("hidden");
			quoteCartFeedbackToast.classList.add("flex");

			if (quoteCartFeedbackTimer) {
				window.clearTimeout(quoteCartFeedbackTimer);
			}

			quoteCartFeedbackTimer = window.setTimeout(() => {
				quoteCartFeedbackToast.classList.add("hidden");
				quoteCartFeedbackToast.classList.remove("flex");
				quoteCartFeedback.textContent = "";
			}, 3200);
		};

		const showQuoteSubmissionToast = () => {
			quoteSubmissionToast.classList.remove("hidden");
			quoteSubmissionToast.classList.add("flex");

			if (quoteSubmissionToastTimer) {
				window.clearTimeout(quoteSubmissionToastTimer);
			}

			quoteSubmissionToastTimer = window.setTimeout(() => {
				quoteSubmissionToast.classList.add("hidden");
				quoteSubmissionToast.classList.remove("flex");
			}, 4200);
		};

		const scrollToQuoteCartOnMobile = () => {
			if (!window.matchMedia("(max-width: 1279px)").matches) {
				return;
			}

			quoteCartPanel.scrollIntoView({ block: "start", behavior: "smooth" });
		};

		const sendNetlifyNotification = async (payload) => {
			const body = new URLSearchParams();

			Object.entries(payload).forEach(([key, value]) => {
				body.append(key, String(value));
			});

			try {
				await fetch("/netlify-form-blueprints", {
					method: "POST",
					headers: { "Content-Type": "application/x-www-form-urlencoded" },
					body: body.toString(),
				});
			} catch {
				// Keep the quote submission successful even if the notification copy fails.
			}
		};

		const formatPhoneNumber = (value) => {
			const digits = value.replace(/\D/g, "").slice(0, 10);

			if (digits.length <= 3) {
				return digits;
			}

			if (digits.length <= 6) {
				return `(${digits.slice(0, 3)}) ${digits.slice(3)}`;
			}

			return `(${digits.slice(0, 3)}) ${digits.slice(3, 6)}-${digits.slice(6)}`;
		};

		const readCart = () => {
			try {
				const stored = localStorage.getItem(storageKey);
				const parsed = stored ? JSON.parse(stored) : [];
				return Array.isArray(parsed) ? parsed : [];
			} catch {
				return [];
			}
		};

		const writeCart = (items) => {
			localStorage.setItem(storageKey, JSON.stringify(items));
		};

		const formatConditionLabel = (value) => {
			switch (value) {
				case "excellent":
					return "Excellent";
				case "light-scratches":
					return "Light scratches";
				case "worn":
					return "Worn";
				default:
					return value;
			}
		};

		const buildQuoteSubmission = (items) => {
			const totalQuantity = items.reduce((sum, item) => sum + item.quantity, 0);
			const totalPayout = items.reduce((sum, item) => sum + item.lineTotal, 0);
			const createdAt = new Date().toLocaleString("en-US", {
				dateStyle: "medium",
				timeStyle: "short",
			});
			const lines = items.map(
				(item, index) =>
					`${index + 1}. ${item.sku} - ${item.description} | ${formatConditionLabel(item.condition)} | ${item.quantity} key${
						item.quantity === 1 ? "" : "s"
					} @ ${currencyFormatter.format(item.unitPrice)} | Line total: ${currencyFormatter.format(item.lineTotal)}`
			);

			return {
				totalQuantity,
				totalPayout,
				createdAt,
				summary: [
					"Quote cart details:",
					"",
					...lines,
					"",
					`Total keys: ${totalQuantity}`,
					`Estimated payout: ${currencyFormatter.format(totalPayout)}`,
					`Created: ${createdAt}`,
				].join("\n"),
			};
		};

		const setConditionAvailability = (enabled) => {
			conditionField.disabled = false;
			conditionGroup.classList.toggle("opacity-55", false);
			conditionLabel.classList.toggle("text-gray-400", false);
			conditionHelp.textContent = enabled
				? "Choose the condition that best matches the key you are sending in."
				: "Choose the condition that best matches the key you are sending in.";
		};

		const getSelectedOption = () => {
			const selected = skuSelect.selectedOptions[0];
			if (!selected) {
				return null;
			}
			return selected;
		};

		const getCurrentQuote = () => {
			const selected = getSelectedOption();
			const quantity = Number.parseInt(quantityField.value, 10) || 0;
			const selectedCondition = conditionField.value;

			if (!selected) {
				return null;
			}

			const standardPrice = Number(selected.dataset.price ?? "0");
			const lightScratchesValue = selected.dataset.lightScratchesPrice;
			const wornValue = selected.dataset.wornPrice;
			const lightScratchesPrice = lightScratchesValue ? Number(lightScratchesValue) : null;
			const wornPrice = wornValue ? Number(wornValue) : null;
			const unitPrice =
				selectedCondition === "light-scratches"
					? lightScratchesPrice ?? standardPrice
					: selectedCondition === "worn"
						? wornPrice ?? standardPrice
						: standardPrice;
			const description = selected.dataset.descriptionLabel ?? selected.textContent?.split("|").slice(1).join("|").trim() ?? selected.value;

			return {
				sku: selected.value,
				description,
				make: selected.dataset.make ?? "Unknown",
				quantity,
				condition: selectedCondition,
				unitPrice,
				lineTotal: unitPrice * quantity,
				hasConditionPrice: lightScratchesPrice !== null || wornPrice !== null,
				inventoryCount: Number(selected.dataset.inventoryCount ?? "0"),
				maxOrderQuantity: Number(selected.dataset.maxOrderQuantity ?? "0"),
			};
		};

		const getRemainingCapacity = (quote) => Math.max(0, quote.maxOrderQuantity - quote.inventoryCount);

		const updatePreview = () => {
			const current = getCurrentQuote();
			const selected = getSelectedOption();
			const hasConditionOptions = Boolean(selected?.dataset.lightScratchesPrice || selected?.dataset.wornPrice);

			setConditionAvailability(hasConditionOptions);

			if (!current || current.quantity < 1) {
				quotePreviewTotal.textContent = currencyFormatter.format(0);
				quotePreviewDetail.textContent = "Select a key from the catalog above to see your estimated payout.";
				quotePreviewSku.textContent = "No key selected yet";
				quotePreviewMake.textContent = "";
				quotePreviewInventory.textContent = "";
				conditionHelp.textContent = "Choose the condition that best matches the key you are sending in.";
				return;
			}

			const quantityLimit = getRemainingCapacity(current);
			quantityField.max = String(quantityLimit || 0);

			if (quantityLimit > 0 && current.quantity > quantityLimit) {
				quantityField.value = String(quantityLimit);
				updatePreview();
				return;
			}

			quotePreviewTotal.textContent = currencyFormatter.format(current.lineTotal);
			quotePreviewSku.textContent = current.sku;
			quotePreviewMake.textContent = `${current.make} key`;
			quotePreviewInventory.textContent =
				quantityLimit > 0
					? `${current.inventoryCount} on hand, accepting up to ${quantityLimit} more`
					: "This key is not accepting more inventory right now";
			quotePreviewDetail.textContent = `${current.quantity} x ${formatConditionLabel(
				current.condition
			)} price at ${currencyFormatter.format(current.unitPrice)} each`;
		};

		const renderCart = () => {
			const items = readCart();
			cartList.replaceChildren();

			const totalQuantity = items.reduce((sum, item) => sum + item.quantity, 0);
			const totalPayout = items.reduce((sum, item) => sum + item.lineTotal, 0);

			cartCount.textContent = String(totalQuantity);
			cartTotal.textContent = currencyFormatter.format(totalPayout);
			cartEmpty.style.display = items.length ? "none" : "block";

			items.forEach((item) => {
				const entry = document.createElement("li");
				entry.className = "rounded-2xl bg-white/5 p-4 ring-1 ring-white/10";
				const wrapper = document.createElement("div");
				wrapper.className = "flex items-start justify-between gap-3";

				const details = document.createElement("div");
				const sku = document.createElement("p");
				sku.className = "font-semibold";
				sku.textContent = item.sku;
				const description = document.createElement("p");
				description.className = "mt-1 text-sm text-gray-300";
				description.textContent = item.description;
				const meta = document.createElement("p");
				meta.className = "mt-1 text-sm text-gray-300";
				meta.textContent = `${formatConditionLabel(item.condition)} | ${item.quantity} key${item.quantity === 1 ? "" : "s"} at ${currencyFormatter.format(item.unitPrice)} each`;
				details.append(sku, description, meta);

				const summary = document.createElement("div");
				summary.className = "text-right";
				const total = document.createElement("p");
				total.className = "font-semibold text-sky-300";
				total.textContent = currencyFormatter.format(item.lineTotal);
				const removeButton = document.createElement("button");
				removeButton.type = "button";
				removeButton.className = "mt-2 text-sm text-white underline decoration-white/30 underline-offset-4";
				removeButton.dataset.removeId = item.id;
				removeButton.textContent = "Remove";
				summary.append(total, removeButton);

				wrapper.append(details, summary);
				entry.appendChild(wrapper);
				cartList.appendChild(entry);
			});

			cartList.querySelectorAll("[data-remove-id]").forEach((button) => {
				button.addEventListener("click", () => {
					const nextItems = readCart().filter((item) => item.id !== button.getAttribute("data-remove-id"));
					writeCart(nextItems);
					renderCart();
				});
			});
		};

		skuSelect.addEventListener("change", updatePreview);
		conditionField.addEventListener("change", updatePreview);
		quantityField.addEventListener("input", updatePreview);
		document.addEventListener("key-catalog-select", (event) => {
			const customEvent = event as CustomEvent<{ sku?: string; condition?: string }>;
			const selectedSku = customEvent.detail?.sku;
			const selectedCondition = customEvent.detail?.condition;
			if (!selectedSku) {
				return;
			}

			const matchingOption = Array.from(skuSelect.options).find((option) => option.value === selectedSku);
			if (!matchingOption) {
				return;
			}

			skuSelect.value = selectedSku;
			if (selectedCondition && Array.from(conditionField.options).some((option) => option.value === selectedCondition)) {
				conditionField.value = selectedCondition;
			}
			skuSelect.dispatchEvent(new Event("change"));
			currentLinePayout.scrollIntoView({ block: "start", behavior: "smooth" });
		});

		form.addEventListener("submit", (event) => {
			event.preventDefault();
			const current = getCurrentQuote();

			if (!current || current.quantity < 1) {
				updatePreview();
				return;
			}

			const quantityLimit = getRemainingCapacity(current);
			const existingItems = readCart();
			const existingSkuQuantity = existingItems
				.filter((item) => item.sku === current.sku)
				.reduce((sum, item) => sum + item.quantity, 0);
			const remainingForCart = Math.max(0, quantityLimit - existingSkuQuantity);

			if (quantityLimit < 1) {
				showQuoteCartFeedback(`${current.sku} is not accepting more inventory right now.`);
				return;
			}

			if (remainingForCart < 1) {
				showQuoteCartFeedback(`You already added the current accepted limit for ${current.sku}.`);
				return;
			}

			if (current.quantity > remainingForCart) {
				quantityField.value = String(remainingForCart);
				updatePreview();
				showQuoteCartFeedback(`You can add up to ${remainingForCart} more of ${current.sku} right now.`);
				return;
			}
			const existingIndex = existingItems.findIndex(
				(item) => item.sku === current.sku && item.condition === current.condition
			);
			let nextItems = existingItems;

			if (existingIndex >= 0) {
				nextItems = existingItems.map((item, index) =>
					index === existingIndex
						? {
								...item,
								quantity: item.quantity + current.quantity,
								lineTotal: item.unitPrice * (item.quantity + current.quantity),
						  }
						: item
				);
			} else {
				nextItems = [
					...existingItems,
					{
						id: crypto.randomUUID(),
						...current,
						createdAt: new Date().toISOString(),
					},
				];
			}

			writeCart(nextItems);
			renderCart();
			quantityField.value = "1";
			updatePreview();
			scrollToQuoteCartOnMobile();
			showQuoteCartFeedback(
				existingIndex >= 0
					? `${current.sku} was added to the existing cart line.`
					: `${current.sku} was added to your quote cart.`
			);
		});

		resetButton.addEventListener("click", () => {
			conditionField.value = "excellent";
			quantityField.value = "1";
			updatePreview();
		});

		addMoreKeysButton.addEventListener("click", () => {
			priceCatalogSection.scrollIntoView({ block: "start", behavior: "smooth" });
		});

		clearCartButton.addEventListener("click", () => {
			writeCart([]);
			renderCart();
			sendQuoteStatus.textContent = "";
		});

		sendQuoteCartButton.addEventListener("click", () => {
			const items = readCart();
			if (!items.length) {
				sendQuoteStatus.textContent = "Add at least one key to your quote before sending.";
				return;
			}

			const submission = buildQuoteSubmission(items);
			quoteRequestSummary.value = submission.summary;
			quoteRequestTotalKeys.value = String(submission.totalQuantity);
			quoteRequestEstimatedPayout.value = currencyFormatter.format(submission.totalPayout);
			quoteRequestSubmittedAt.value = submission.createdAt;
			quoteRequestSourcePage.value = window.location.href;
			quoteRequestClientTimezone.value = Intl.DateTimeFormat().resolvedOptions().timeZone ?? "";
			quoteRequestClientUtcOffset.value = String(new Date().getTimezoneOffset() * -1);
			quoteRequestItemsJson.value = JSON.stringify(
				items.map((item) => ({
					sku: item.sku,
					make: item.make,
					description: item.description,
					condition: item.condition,
					quantity: item.quantity,
					unitPrice: item.unitPrice,
					lineTotal: item.lineTotal,
				}))
			);
			quoteRequestStatus.textContent = "";
			sendQuoteStatus.textContent = "";
			openQuoteRequest();
			window.setTimeout(() => {
				quoteRequestName.focus();
			}, 50);
		});

		closeQuoteRequestButtons.forEach((button) => {
			button.addEventListener("click", closeQuoteRequest);
		});

		quoteRequestPhone.addEventListener("input", () => {
			quoteRequestPhone.value = formatPhoneNumber(quoteRequestPhone.value);
		});

		quoteRequestState.addEventListener("input", () => {
			quoteRequestState.value = quoteRequestState.value.replace(/[^a-z]/gi, "").toUpperCase().slice(0, 2);
		});

		quoteRequestZip.addEventListener("input", () => {
			quoteRequestZip.value = quoteRequestZip.value.replace(/\D/g, "").slice(0, 5);
		});

		quoteRequestForm.addEventListener("submit", async (event) => {
			event.preventDefault();

			if (!quoteRequestForm.reportValidity()) {
				return;
			}

			const formData = new FormData(quoteRequestForm);
			const payload = new URLSearchParams();

			formData.forEach((value, key) => {
				payload.append(key, String(value));
			});

			const submitButton = quoteRequestForm.querySelector('button[type="submit"]');
			if (!(submitButton instanceof HTMLButtonElement)) {
				return;
			}

			submitButton.disabled = true;
			quoteRequestStatus.textContent = "Sending your quote...";

			try {
				const response = await fetch("/api/quote-request.json", {
					method: "POST",
					headers: { "Content-Type": "application/x-www-form-urlencoded" },
					body: payload.toString(),
				});

				if (!response.ok) {
					throw new Error("Submission failed");
				}

				sendQuoteStatus.textContent = "Your quote was sent successfully. We will reach out soon.";
				quoteRequestStatus.textContent = "Your quote was sent successfully.";
				void sendNetlifyNotification({
					"form-name": "quote-notification",
					customer_name: quoteRequestName.value,
					customer_email: quoteRequestEmail.value,
					customer_phone: quoteRequestPhone.value,
					customer_address: quoteRequestAddress.value,
					customer_city: quoteRequestCity.value,
					customer_state: quoteRequestState.value,
					customer_zip: quoteRequestZip.value,
					total_keys: quoteRequestTotalKeys.value,
					estimated_payout: quoteRequestEstimatedPayout.value,
					quote_summary: quoteRequestSummary.value,
					submitted_at: quoteRequestSubmittedAt.value,
					source_page: quoteRequestSourcePage.value,
					client_timezone: quoteRequestClientTimezone.value,
					client_utc_offset_minutes: quoteRequestClientUtcOffset.value,
					admin_review_url: `${window.location.origin}/admin/`,
				});
				showQuoteSubmissionToast();
				quoteRequestForm.reset();
				window.setTimeout(closeQuoteRequest, 900);
			} catch {
				quoteRequestStatus.textContent = "Your quote could not be sent right now. Please try again.";
			} finally {
				submitButton.disabled = false;
			}
		});

		document.addEventListener("keydown", (event) => {
			if (event.key === "Escape" && quoteRequestForm.classList.contains("flex")) {
				closeQuoteRequest();
			}
		});

		skuSelect.selectedIndex = -1;
		conditionField.value = "excellent";
		updatePreview();
		renderCart();
	});
</script>

